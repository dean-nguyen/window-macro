{
  "name": "Onmyoji - Demon Sealing",
  "description": "Auto-fight Earth Demons / Sealing (地鬼 / 封魔) dailies; stops when attempts run out. STARTER: open the demon battle screen first (see CAPTURE-GUIDE.md).",
  "background": true,
  "target_window": "Onmyoji",
  "loop": true,
  "loop_delay_ms": 1000,
  "actions": [
    {
      "type": "image_check",
      "template": "templates/onmyoji_no_attempts.png",
      "threshold": 0.85,
      "on_found": [ { "type": "stop" } ]
    },
    {
      "type": "find_and_click",
      "template": "templates/onmyoji_challenge_again.png",
      "threshold": 0.85,
      "on_not_found": [
        { "type": "find_and_click", "template": "templates/onmyoji_battle_ready.png", "threshold": 0.85 }
      ]
    },
    { "type": "image_wait", "template": "templates/onmyoji_victory.png", "timeout_ms": 120000, "poll_ms": 1000 },
    { "type": "find_and_click", "template": "templates/onmyoji_reward_confirm.png", "threshold": 0.80 }
  ]
}
