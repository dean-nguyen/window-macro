{
  "name": "Onmyoji - Bounty Seals",
  "description": "Auto-clear daily Bounty Seals (悬赏封印). Resilient poll: STOPS on CAPTCHA (anti-ban) or when daily attempts are used up; auto-dismisses level-up, defeat and reconnect popups. STARTER: capture templates via Guided Capture.",
  "background": true,
  "target_window": "Onmyoji",
  "loop": true,
  "loop_delay_ms": 800,
  "actions": [
    { "type": "image_check", "template": "templates/onmyoji_captcha.png", "threshold": 0.80, "on_found": [ { "type": "stop" } ] },
    { "type": "find_and_click", "template": "templates/onmyoji_reconnect_retry.png", "threshold": 0.85, "on_not_found": [] },
    { "type": "find_and_click", "template": "templates/onmyoji_level_up_ok.png", "threshold": 0.85, "on_not_found": [] },
    { "type": "image_check", "template": "templates/onmyoji_inventory_full.png", "threshold": 0.85, "on_found": [ { "type": "stop" } ] },
    { "type": "find_and_click", "template": "templates/onmyoji_defeat_ok.png", "threshold": 0.85, "on_not_found": [] },
    { "type": "image_check", "template": "templates/onmyoji_no_attempts.png", "threshold": 0.85, "on_found": [ { "type": "stop" } ] },
    { "type": "find_and_click", "template": "templates/onmyoji_reward_confirm.png", "threshold": 0.80, "on_not_found": [] },
    {
      "type": "find_and_click",
      "template": "templates/onmyoji_challenge_again.png",
      "threshold": 0.85,
      "on_not_found": [
        { "type": "find_and_click", "template": "templates/onmyoji_battle_ready.png", "threshold": 0.85 }
      ]
    }
  ]
}
